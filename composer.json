{
    "name": "mathiasgrimm/laravel-puff",
    "description": "Keep your scale-to-zero Laravel app warm. A tiny activity-driven warmer that pre-warms the stack so users don't hit cold starts.",
    "keywords": [
        "laravel",
        "scale-to-zero",
        "cold-start",
        "warmup",
        "serverless"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mathias Grimm",
            "email": "mathiasgrimm@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0 || ^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "MathiasGrimm\\Puff\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MathiasGrimm\\Puff\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MathiasGrimm\\Puff\\PuffServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
